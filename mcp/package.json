{
  "name": "ixodocs-mcp",
  "version": "0.1.0",
  "description": "MCP server for Ixopay, TokenEx and Congrify payment platform documentation",
  "type": "module",
  "bin": {
    "ixodocs-mcp": "./dist/cli.js"
  },
  "main": "./dist/server.js",
  "files": ["dist/", "bundle/"],
  "scripts": {
    "build:bundle": "tsx scripts/build-bundle.ts",
    "build:ts": "tsc",
    "build": "npm run build:bundle && npm run build:ts && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "gray-matter": "^4.0.3",
    "minisearch": "^7.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
